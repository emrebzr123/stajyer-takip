# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password
DB_NAME=intern_tracker

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# App
PORT=3001
NODE_ENV=development
# CORS: Frontend'in canlı adresi (Vercel/Railway *.vercel.app ve *.railway.app
# zaten otomatik izinli — bu sadece özel bir domain kullanıyorsanız gerekir)
FRONTEND_URL=http://localhost:3000

# File Upload
UPLOAD_DEST=./uploads
MAX_FILE_SIZE=10485760

# E-posta (Gmail — "Uygulama Şifresi" kullanın, normal hesap şifresi değil)
GMAIL_USER=
GMAIL_PASS=
# Staj sonu değerlendirme anketi linki (Google Form vb.)
EVALUATION_FORM_URL=

# Web Push (PWA bildirimleri — telefon kilitliyken/uygulama kapalıyken de
# bildirim gösterebilmek için). Anahtar üretmek için:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
# Boş bırakılırsa push devre dışı kalır, uygulama içi zil normal çalışır.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:destek@electromtech.com
