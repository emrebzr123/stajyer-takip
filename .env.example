# ─── API (Railway) Environment Variables ─────────────────────────────────────
# Bu değerleri Railway → API Servisi → Variables sekmesine girin
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL Bağlantısı (Railway otomatik sağlar, kopyalayıp yapıştırın)
DB_HOST=RAILWAY_POSTGRES_HOST
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=RAILWAY_POSTGRES_SIFRESI
DB_NAME=railway

# JWT
JWT_SECRET=cok-guclu-ve-uzun-bir-sifre-yazin-buraya-123!
JWT_EXPIRES_IN=7d

# Uygulama
PORT=3001
NODE_ENV=production

# CORS (Vercel'deki frontend URL'iniz)
# Örnek: https://stajyer-takip-6wsx.vercel.app
FRONTEND_URL=https://VERCEL_FRONTEND_URL_YAZIN

# Belge yükleme
UPLOAD_DEST=./uploads
MAX_FILE_SIZE=10485760

# ─── E-posta (Gmail) ──────────────────────────────────────────────────────────
# ─── E-posta (Brevo — HTTPS REST API, SMTP DEĞİL) ────────────────────────────
# NOT: Railway gibi PaaS sağlayıcıları outbound SMTP portlarını (465/587)
# engellediği için Gmail SMTP çalışmıyordu. Artık Brevo'nun HTTPS API'si
# kullanılıyor — bu engellemeden etkilenmez.
# 1) https://www.brevo.com üzerinden ücretsiz hesap açın (kredi kartı istemez)
# 2) Dashboard → Senders, Domains & Dedicated IPs → Senders → mevcut
#    Gmail/Hotmail adresinizi "Single Sender" olarak ekleyip doğrulayın
#    (gelen onay mailindeki linke tıklamanız yeterli, domain gerekmez)
# 3) Dashboard → SMTP & API → API Keys → yeni bir API key oluşturun
BREVO_API_KEY=BREVO_API_ANAHTARINIZ_BURAYA
BREVO_SENDER_EMAIL=DOGRULANMIŞ_GONDEREN_ADRESINIZ_BURAYA

# (Opsiyonel) İkinci bir gönderim hesabı kullanıyorsanız
HOTMAIL_USER=
HOTMAIL_PASS=

# Staj sonu değerlendirme anketi linki (Google Form vb., opsiyonel)
EVALUATION_FORM_URL=

# ─── Web Push (PWA bildirimleri) ──────────────────────────────────────────────
# Üretmek için: node -e "console.log(require('web-push').generateVAPIDKeys())"
# Boş bırakılırsa push bildirimleri devre dışı kalır, uygulama içi zil etkilenmez.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:destek@electromtech.com


# ─── Vercel (Frontend) Environment Variables ──────────────────────────────────
# Bu değeri Vercel Dashboard → Settings → Environment Variables'a girin
# ─────────────────────────────────────────────────────────────────────────────

# Railway'deki API URL'iniz — SONUNDA /api/v1 OLMALI
# Örnek: https://stajyer-takip-production.up.railway.app/api/v1
NEXT_PUBLIC_API_URL=https://RAILWAY_API_URL_YAZIN/api/v1
